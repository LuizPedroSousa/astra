    },
    {
      "id": "shaders::cas_composite",
      "type": "Shader",
      "vertex": "@engine/shaders/cas-composite.axsl",
      "fragment": "@engine/shaders/cas-composite.axsl"
    }
  ],
  "render_graph": {
    "resources": {
      "shadow_map": {
        "format": "depth32f",
        "size": "window",
        "usage": ["depth_stencil_attachment", "sampled"]
      },
      "scene_color": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "scene_depth": {
        "format": "depth32f",
        "size": "window",
        "usage": ["depth_stencil_attachment"]
      },
      "bloom_extract": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "entity_pick": {
        "format": "r32i",
        "size": "window",
        "usage": ["color_attachment", "transfer_src"]
      },
      "bloom": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "present": {
        "format": "rgba8",
        "size": "window",
        "usage": ["color_attachment", "sampled", "transfer_src"]
      },
      "g_position": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_normal": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_geometric_normal": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_albedo": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_emissive": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_entity_id": {
        "format": "r32i",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "g_velocity": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "ssao": {
        "format": "rgba8",
        "size": { "source": "window", "op": "divide", "value": 2 },
        "usage": ["color_attachment", "sampled"]
      },
      "ssao_blur": {
        "format": "rgba8",
        "size": { "source": "window", "op": "divide", "value": 2 },
        "usage": ["color_attachment", "sampled"]
      },
      "ssgi": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "ssgi_blur": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "ssgi_temporal": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "ssgi_history": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"],
        "lifetime": "persistent"
      },
      "ssr": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "ssr_blur": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "volumetric_fog": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "volumetric_blur_h": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "volumetric_blur": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "volumetric_temporal": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "volumetric_history": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"],
        "lifetime": "persistent"
      },
      "lens_flare": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "motion_blur": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "chromatic_aberration": {
        "format": "rgba8",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "vignette": {
        "format": "rgba8",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "film_grain": {
        "format": "rgba8",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "depth_of_field": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "god_rays": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "taa_output": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      },
      "taa_history": {
        "format": "rgba16f",
        "size": "window",
        "usage": ["color_attachment", "sampled"],
        "lifetime": "persistent"
      },
      "cas": {
        "format": "rgba8",
        "size": "window",
        "usage": ["color_attachment", "sampled"]
      }
    },
    "passes": [
      {
        "id": "shadow",
        "type": "builtin::shadow",
        "dependencies": {
          "shaders": { "shadow_shader": "shaders::shadow_map" }
        },
        "use": [
          { "resource": "shadow_map", "aspect": "depth", "usage": "depth_attachment_write" }
        ]
      },
      {
        "id": "geometry",
        "type": "builtin::geometry",
        "dependencies": {
          "shaders": { "geometry_shader": "shaders::g_buffer" }
        },
        "use": [
          { "resource": "g_position", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_normal", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_geometric_normal", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_albedo", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_emissive", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_entity_id", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "g_velocity", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "scene_depth", "aspect": "depth", "usage": "depth_attachment_write" }
        ]
      },
      {
        "id": "gbuffer_blend",
        "type": "builtin::gbuffer_blend",
        "dependencies": {
          "shaders": { "gbuffer_blend_shader": "shaders::g_buffer_blend" }
        },
        "use": [
          { "resource": "g_albedo", "aspect": "color0", "usage": "color_attachment_write" },
          { "resource": "scene_depth", "aspect": "depth", "usage": "depth_attachment_read" }
        ]
      },
      {
        "id": "ssao",
        "type": "builtin::ssao",
        "dependencies": {
          "shaders": { "ssao_shader": "shaders::ssao" },
          "textures": { "noise_texture": "noise_texture" }
        },
        "use": [
