    },
    {
      "id": "icons::mesh",
      "type": "Svg",
      "path": "@engine/icons/mesh.svg"
    },
    {
      "id": "icons::directory",
      "type": "Svg",
      "path": "@engine/icons/directory.svg"
    },
    {
      "id": "icons::file",
      "type": "Svg",
      "path": "@engine/icons/file.svg"
    },
    {
      "id": "cubemaps::skybox",
      "type": "Texture3D",
      "equirectangular": "textures/skybox/qwantani_dusk_2_puresky_4k.exr"
    },
    {
      "id": "models::sponza_atrium",
      "asset": "models/sponza-atrium/sponza.axmodel"
    },
    {
      "id": "models::sponza_curtains",
      "asset": "models/sponza-intel-curtains/curtains.axmodel"
    },
    {
      "id": "models::bistro_exterior",
      "asset": "models/bistro/bistro.axmodel"
    },
    {
      "id": "textures::brick::base_color",
      "asset": "textures/brick/base_color.axtexture"
    },
    {
      "id": "textures::brick::normal",
      "asset": "textures/brick/normal.axtexture"
    },
    {
      "id": "textures::brick::metallic",
      "asset": "textures/brick/metallic.axtexture"
    },
    {
      "id": "textures::brick::roughness",
      "asset": "textures/brick/roughness.axtexture"
    },
    {
      "id": "textures::brick::occlusion",
      "asset": "textures/brick/occlusion.axtexture"
    },
    {
      "id": "textures::brick::displacement",
      "asset": "textures/brick/displacement.axtexture"
    },
    {
      "id": "materials::brick",
      "asset": "materials/brick.axmaterial"
    },
    {
      "id": "shaders::post_processing",
      "type": "Shader",
      "vertex": "@engine/shaders/post-process.axsl",
      "fragment": "@engine/shaders/post-process.axsl"
    },
    {
