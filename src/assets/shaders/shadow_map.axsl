@version 450;

@in
interface Mesh {
  @location(0) 
  vec3 position;
}

@std430 
@binding(0) 
in InstanceBuffer {
    mat4 models[];
} instance;


@uniform
interface Light {
  mat4 light_space_matrix;
  mat4 g_model;
}

@vertex
fn main(Mesh mesh, Light light) -> void {
    mat4 model = light.g_model;

    gl_Position = light.light_space_matrix * model * vec4(mesh.position, 1.0);
}

@fragment
fn main() -> void
{
    // gl_FragDepth = gl_FragCoord.z;
}
